APP_NAME="School La Providence ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# SQLite (recommended for Termux — no server needed)
DB_CONNECTION=sqlite

# MySQL alternative:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=providence_erp
# DB_USERNAME=root
# DB_PASSWORD=

CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=database

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,127.0.0.1

FILESYSTEM_DISK=local
